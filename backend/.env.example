# ═══════════════════════════════════════════════════════════════
# PredictIQ Backend — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# Where to find these values:
#   Supabase Dashboard → Project Settings → API
# ═══════════════════════════════════════════════════════════════

# Supabase — Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase — Project Settings → API → anon public key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase — Project Settings → API → service_role secret key
# WARNING: Never expose this key in frontend code or public repos
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase — Project Settings → API → JWT Secret
# Used to verify JWT tokens from Supabase Auth
JWT_SECRET=your-supabase-jwt-secret

# Supabase Storage bucket name (create in Dashboard → Storage)
SUPABASE_STORAGE_BUCKET=project-docs

# CORS — Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ML Model artifact paths (relative to backend/ directory)
ML_MODEL_PATH=./ml/predictiq_best_model.pkl
ML_SCALER_PATH=./ml/predictiq_scaler.pkl
ML_FEATURES_PATH=./ml/predictiq_features.json

# Application settings
DEFAULT_HOURLY_RATE_USD=75
APP_ENV=development
APP_VERSION=2.0.0
