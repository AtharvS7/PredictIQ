# ═══════════════════════════════════════════════════════════════
# Predictify Backend — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Neon PostgreSQL — connection string from Neon Dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Firebase Admin SDK — use ONE of these two options:
# Option A: Path to service account JSON file (local dev)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# Option B: Raw JSON string (Codespaces / Railway / Docker)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# CORS — Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ML Model artifact paths (relative to backend/ directory)
ML_MODEL_PATH=./ml/Predictify_best_model.pkl
ML_SCALER_PATH=./ml/Predictify_scaler.pkl
ML_FEATURES_PATH=./ml/Predictify_features.json

# Application settings
DEFAULT_HOURLY_RATE_USD=75
APP_ENV=development
APP_VERSION=3.0.0
