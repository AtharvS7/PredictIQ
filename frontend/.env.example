# ═══════════════════════════════════════════════════════════════
# PredictIQ Frontend — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Firebase — Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Backend API base URL
# Development (Vite proxy handles /api → localhost:8000): /api/v1
# Production (direct backend URL): https://your-backend-domain.com/api/v1
VITE_API_BASE_URL=/api/v1

# Environment
VITE_APP_ENV=development
