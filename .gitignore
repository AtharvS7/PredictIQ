# ═══════════════════════════════════════════
# PredictIQ — Root .gitignore
# ═══════════════════════════════════════════

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Environment
.env
.env.*
!.env.example
!.env.test.example

# Firebase credentials (NEVER commit)
firebase-service-account.json
**/firebase-service-account.json
predictiq-*-firebase-adminsdk-*.json

# ML artifacts (keep .pkl models tracked — they're essential and <10MB)
# backend/ml/*.pkl  ← TRACKED: required for app to work
backend/ml/*.png
backend/ml/training_log_*.txt
backend/ml/artifacts/

# Node
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
*.iml

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/

# Docker
.docker/

# Code review graph
.code-review-graph/
tooling/code-review-graph/.cache/

# Antigravity
.gemini/

# AI tool configs (editor-specific, not project code)
.claude/
.cursorrules
.windsurfrules
.mcp.json
.opencode.json
AGENTS.md
CLAUDE.md
GEMINI.md

# Tooling (local dev utilities)
tooling/

# Jupyter notebooks at root (keep only in backend/ml/)
/*.ipynb

